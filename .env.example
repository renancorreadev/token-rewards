# RPC endpoint da rede alvo (ex: Sepolia, Polygon, Mainnet)
RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# Private key da conta que fará o deploy (sem 0x prefix)
PRIVATE_KEY=

# Admin address que receberá DEFAULT_ADMIN_ROLE, MINTER_ROLE e DISTRIBUTOR_ROLE
ADMIN_ADDRESS=

# URI base dos metadados ERC-1155 (ex: https://api.example.com/metadata/{id}.json)
TOKEN_URI=

# API key do block explorer para verificação (Etherscan, Polygonscan, etc.)
ETHERSCAN_API_KEY=
